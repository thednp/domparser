{
  "name": "@thednp/domparser",
  "version": "0.1.8",
  "description": "🍝 Super light HTML parser for isomorphic applications.",
  "keywords": [
    "domparser",
    "html",
    "dom",
    "parser"
  ],
  "license": "MIT",
  "author": "thednp",
  "type": "module",
  "browser": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "module": "./dist/index.js",
  "commonjs": "./dist/index.cjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dom": {
      "import": "./dist/dom.js",
      "require": "./dist/dom.cjs"
    },
    "./dom-parser": {
      "import": "./dist/dom-parser.js",
      "require": "./dist/dom-parser.cjs"
    },
    "./parser": {
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "pre-test": "pnpm clean-coverage",
    "dev": "vite serve demo --port 3000",
    "test": "pnpm pre-test && vitest --browser.headless",
    "clean-coverage": "rm -rf coverage .nyc_output .coverage",
    "badges": "npx -p dependency-version-badge update-badge typescript vitest vite",
    "format": "deno fmt src",
    "lint": "pnpm lint:ts && pnpm check:ts",
    "lint:ts": "deno lint src",
    "check:ts": "tsc --noEmit",
    "fix:ts": "deno lint src --fix",
    "build": "tsdown",
    "prepublishOnly": "pnpm up --latest && pnpm format && pnpm lint && pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thednp/domparser.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/thednp/domparser/issues"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-strip-comments": "^0.0.9",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.6.12"
}
